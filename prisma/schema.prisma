generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
}

model Vehicle {
  id              String            @id @default(cuid())
  registrationNo  String            @unique
  name            String
  type            VehicleType
  maxLoadCapacity Float
  odometer        Float             @default(0)
  acquisitionCost Float
  status          VehicleStatus     @default(AVAILABLE)
  region          String?
  createdAt       DateTime          @default(now())
  expenses        Expense[]
  fuelLogs        FuelLog[]
  maintenanceLogs MaintenanceLog[]
  trips           Trip[]
  documents       VehicleDocument[]
}

model Driver {
  id              String          @id @default(cuid())
  name            String
  licenseNumber   String          @unique
  licenseCategory LicenseCategory
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Int             @default(100)
  status          DriverStatus    @default(AVAILABLE)
  createdAt       DateTime        @default(now())
  trips           Trip[]
}

model Trip {
  id              String     @id @default(cuid())
  tripCode        String     @unique
  source          String
  destination     String
  vehicleId       String?
  driverId        String?
  cargoWeight     Float
  plannedDistance Float
  finalOdometer   Float?
  fuelConsumed    Float?
  status          TripStatus @default(DRAFT)
  cancelReason    String?
  createdAt       DateTime   @default(now())
  completedAt     DateTime?
  expenses        Expense[]
  fuelLogs        FuelLog[]
  driver          Driver?    @relation(fields: [driverId], references: [id])
  vehicle         Vehicle?   @relation(fields: [vehicleId], references: [id])
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String
  serviceType String
  cost        Float
  date        DateTime
  status      MaintenanceStatus @default(ACTIVE)
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  tripId    String?
  date      DateTime
  liters    Float
  cost      Float
  trip      Trip?    @relation(fields: [tripId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id        String   @id @default(cuid())
  tripId    String?
  vehicleId String?
  toll      Float    @default(0)
  other     Float    @default(0)
  date      DateTime @default(now())
  trip      Trip?    @relation(fields: [tripId], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
}

model VehicleDocument {
  id         String    @id @default(cuid())
  vehicleId  String
  type       String
  fileUrl    String
  expiryDate DateTime?
  uploadedAt DateTime  @default(now())
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Settings {
  id           String  @id @default(cuid())
  depotName    String  @default("Main Depot")
  currency     String  @default("INR")
  distanceUnit String  @default("km")
  ratePerKm    Float   @default(25)
  adminEmail   String?
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum LicenseCategory {
  LMV
  HMV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}
